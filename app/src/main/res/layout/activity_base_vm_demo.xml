<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/demo_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvIntro"
            style="@style/DemoBodyText" />

        <TextView
            android:id="@+id/tvState"
            android:layout_width="match_parent"
            android:layout_height="88dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_demo_state"
            android:gravity="center"
            android:textColor="@color/demo_accent"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvLastState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/demo_secondary_text"
            android:textSize="14sp" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:columnCount="2">

            <Button
                android:id="@+id/btnLoading"
                style="@style/DemoGridButton"
                android:text="@string/demo_show_loading" />

            <Button
                android:id="@+id/btnContent"
                style="@style/DemoGridButton"
                android:text="@string/demo_vm_content" />

            <Button
                android:id="@+id/btnEmpty"
                style="@style/DemoGridButton"
                android:text="@string/demo_vm_empty" />

            <Button
                android:id="@+id/btnError"
                style="@style/DemoGridButton"
                android:text="@string/demo_vm_error" />

            <Button
                android:id="@+id/btnToast"
                style="@style/DemoGridButton"
                android:text="@string/demo_vm_toast" />

            <Button
                android:id="@+id/btnConfirm"
                style="@style/DemoGridButton"
                android:text="@string/demo_vm_confirm" />
        </GridLayout>
    </LinearLayout>
</ScrollView>
