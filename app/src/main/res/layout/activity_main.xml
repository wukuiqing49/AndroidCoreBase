<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/demo_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="16dp"
        android:paddingEnd="18dp"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/tvIntro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="4dp"
            android:text="@string/demo_home_intro"
            android:textColor="@color/demo_secondary_text"
            android:textSize="15sp" />

        <LinearLayout
            android:id="@+id/rowTitle"
            style="@style/DemoMenuRow"
            android:layout_marginTop="20dp">

            <ImageView
                android:id="@+id/ivTitleIcon"
                style="@style/DemoMenuIcon" />

            <LinearLayout style="@style/DemoMenuTextBox">

                <TextView
                    android:id="@+id/tvTitleName"
                    style="@style/DemoMenuTitle" />

                <TextView
                    android:id="@+id/tvTitleDesc"
                    style="@style/DemoMenuDesc" />
            </LinearLayout>

            <ImageView style="@style/DemoMenuArrow" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowVm"
            style="@style/DemoMenuRow">

            <ImageView
                android:id="@+id/ivVmIcon"
                style="@style/DemoMenuIcon" />

            <LinearLayout style="@style/DemoMenuTextBox">

                <TextView
                    android:id="@+id/tvVmName"
                    style="@style/DemoMenuTitle" />

                <TextView
                    android:id="@+id/tvVmDesc"
                    style="@style/DemoMenuDesc" />
            </LinearLayout>

            <ImageView style="@style/DemoMenuArrow" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowList"
            style="@style/DemoMenuRow">

            <ImageView
                android:id="@+id/ivListIcon"
                style="@style/DemoMenuIcon" />

            <LinearLayout style="@style/DemoMenuTextBox">

                <TextView
                    android:id="@+id/tvListName"
                    style="@style/DemoMenuTitle" />

                <TextView
                    android:id="@+id/tvListDesc"
                    style="@style/DemoMenuDesc" />
            </LinearLayout>

            <ImageView style="@style/DemoMenuArrow" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowWidget"
            style="@style/DemoMenuRow">

            <ImageView
                android:id="@+id/ivWidgetIcon"
                style="@style/DemoMenuIcon" />

            <LinearLayout style="@style/DemoMenuTextBox">

                <TextView
                    android:id="@+id/tvWidgetName"
                    style="@style/DemoMenuTitle" />

                <TextView
                    android:id="@+id/tvWidgetDesc"
                    style="@style/DemoMenuDesc" />
            </LinearLayout>

            <ImageView style="@style/DemoMenuArrow" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
