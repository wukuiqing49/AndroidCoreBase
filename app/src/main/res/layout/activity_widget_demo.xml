<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/demo_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="18dp"
        android:paddingEnd="20dp"
        android:paddingBottom="28dp">

        <TextView
            android:id="@+id/tvDependency"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/demo_primary_text"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:lineSpacingExtra="4dp"
            android:textColor="@color/demo_secondary_text"
            android:textSize="15sp" />

        <com.wkq.base.widget.VerifyCodeInputView
            android:id="@+id/verifyCode"
            android:layout_width="match_parent"
            android:layout_height="76dp"
            android:layout_marginTop="28dp"
            app:verifyCode_cellHeight="54dp"
            app:verifyCode_cellSpacing="12dp"
            app:verifyCode_cellWidth="54dp"
            app:verifyCode_filledBgColor="@color/demo_code_filled_bg"
            app:verifyCode_filledBorderColor="@color/demo_code_filled_border"
            app:verifyCode_focusedBgColor="@color/demo_code_focused_bg"
            app:verifyCode_focusedBorderColor="@color/demo_accent"
            app:verifyCode_length="4"
            app:verifyCode_normalBgColor="@color/demo_code_normal_bg"
            app:verifyCode_normalBorderColor="@color/demo_code_normal_border"
            app:verifyCode_textColor="@color/demo_primary_text"
            app:verifyCode_textSize="20sp" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:textColor="@color/demo_secondary_text"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnFillCode"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="@string/demo_fill_code" />

            <Space
                android:layout_width="12dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/btnClearCode"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="@string/demo_clear_code" />
        </LinearLayout>

        <com.wkq.base.widget.MultiSpanTextView
            android:id="@+id/tvProtocol"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:lineSpacingExtra="4dp"
            android:textColor="@color/demo_secondary_text"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnDialog"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="26dp"
            android:text="@string/demo_show_dialog" />

        <Button
            android:id="@+id/btnLoading"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="12dp"
            android:text="@string/demo_show_loading" />
    </LinearLayout>
</ScrollView>
