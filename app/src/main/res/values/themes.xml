<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.CoreBaseDemo" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="colorPrimary">@color/demo_accent</item>
        <item name="colorPrimaryVariant">@color/demo_accent</item>
        <item name="colorAccent">@color/demo_accent</item>
    </style>

    <style name="DemoMenuRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">12dp</item>
        <item name="android:background">@drawable/bg_demo_menu_row</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:foreground">?android:attr/selectableItemBackground</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:minHeight">84dp</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:padding">14dp</item>
    </style>

    <style name="DemoMenuIcon">
        <item name="android:layout_width">44dp</item>
        <item name="android:layout_height">44dp</item>
        <item name="android:background">@drawable/bg_demo_icon</item>
        <item name="android:padding">10dp</item>
        <item name="android:tint">@color/demo_accent</item>
    </style>

    <style name="DemoMenuTextBox">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">14dp</item>
        <item name="android:layout_marginEnd">10dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="DemoMenuTitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/demo_primary_text</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="DemoMenuDesc">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">4dp</item>
        <item name="android:lineSpacingExtra">2dp</item>
        <item name="android:textColor">@color/demo_secondary_text</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="DemoMenuArrow">
        <item name="android:layout_width">24dp</item>
        <item name="android:layout_height">24dp</item>
        <item name="android:src">@drawable/ic_md_chevron_right</item>
        <item name="android:tint">@color/demo_secondary_text</item>
    </style>

    <style name="DemoBodyText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:lineSpacingExtra">4dp</item>
        <item name="android:textColor">@color/demo_secondary_text</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="DemoActionButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">50dp</item>
        <item name="android:layout_marginTop">14dp</item>
    </style>

    <style name="DemoGridButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">50dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_margin">5dp</item>
    </style>
</resources>
